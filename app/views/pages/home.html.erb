<style>
  :root{
    --cf5-white:#ffffff;
    --cf5-text:#0f172a;
    --cf5-muted:#64748b;
    --cf5-border:#e2e8f0;
    --cf5-primary:#2563eb;
    --cf5-primary-2:#60a5fa;
    --cf5-soft:#eff6ff;
    --cf5-soft-bg:#f8fbff;
    --cf5-dark:#0b1220;
    --cf5-success:#16a34a;
    --cf5-shadow:0 24px 70px rgba(15,23,42,.10);
    --cf5-shadow-soft:0 12px 32px rgba(15,23,42,.06);
  }

  *{box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{
    margin:0;
    font-family:Inter,system-ui,sans-serif;
    background:var(--cf5-white);
    color:var(--cf5-text);
  }
  a{text-decoration:none;color:inherit}
  .cf5-page{overflow-x:hidden}
  .cf5-container{max-width:1260px;margin:0 auto;padding:0 20px}

  .cf5-navbar{
    position:sticky;top:0;z-index:1000;
    background:rgba(255,255,255,.82);
    backdrop-filter:blur(18px);
    border-bottom:1px solid rgba(226,232,240,.8);
  }
  .cf5-nav-inner{
    min-height:84px;display:flex;align-items:center;justify-content:space-between;gap:20px;
  }
  .cf5-brand{display:flex;align-items:center;gap:14px}
  .cf5-brand-logo{
    width:48px;height:48px;border-radius:16px;
    background:linear-gradient(135deg,var(--cf5-primary),var(--cf5-primary-2));
    color:#fff;display:flex;align-items:center;justify-content:center;
    font-size:1.4rem;font-weight:900;box-shadow:0 14px 28px rgba(37,99,235,.24);
  }
  .cf5-brand-title{display:block;font-size:1.18rem;font-weight:900;line-height:1}
  .cf5-brand-sub{display:block;margin-top:4px;color:var(--cf5-muted);font-size:.78rem}

  .cf5-nav-links{display:flex;align-items:center;gap:24px}
  .cf5-nav-links a{font-weight:600;color:#334155;font-size:.95rem;transition:.2s ease}
  .cf5-nav-links a:hover{color:var(--cf5-primary)}

  .cf5-nav-actions{display:flex;gap:12px;align-items:center}
  .cf5-btn{
    display:inline-flex;align-items:center;justify-content:center;gap:10px;
    padding:14px 22px;border-radius:14px;font-weight:800;border:1px solid transparent;transition:.25s ease;
  }
  .cf5-btn:hover{transform:translateY(-1px)}
  .cf5-btn-primary{
    color:#fff;background:linear-gradient(135deg,var(--cf5-primary),var(--cf5-primary-2));
    box-shadow:0 16px 34px rgba(37,99,235,.22);
  }
  .cf5-btn-light{background:#fff;color:var(--cf5-text);border-color:var(--cf5-border)}
  .cf5-btn-outline{background:transparent;color:var(--cf5-text);border-color:var(--cf5-border)}
  .cf5-btn-light:hover,.cf5-btn-outline:hover{background:#f8fafc}
  .cf5-full-btn{width:100%}

  .cf5-menu-toggle{
    display:none;border:none;background:transparent;font-size:1.7rem;cursor:pointer;color:var(--cf5-text)
  }
  .cf5-mobile-menu{
    display:none;padding:12px 0 22px;border-top:1px solid var(--cf5-border)
  }
  .cf5-mobile-menu a{
    display:block;padding:12px 0;font-weight:600;color:#334155
  }
  .cf5-mobile-actions{display:flex;flex-direction:column;gap:12px;margin-top:14px}
  .cf5-mobile-menu.cf5-open{display:block}

  .cf5-hero{
    position:relative;padding:100px 0 82px;
    background:linear-gradient(180deg,#f8fbff 0%,#ffffff 58%,#ffffff 100%);
  }
  .cf5-gradient-orb{
    position:absolute;border-radius:999px;filter:blur(60px);opacity:.55;pointer-events:none;
  }
  .cf5-orb-1{
    width:360px;height:360px;background:rgba(59,130,246,.18);top:-80px;left:-100px;
  }
  .cf5-orb-2{
    width:320px;height:320px;background:rgba(96,165,250,.16);right:-60px;top:100px;
  }
  .cf5-grid-overlay{
    position:absolute;inset:0;
    background-image:linear-gradient(rgba(15,23,42,.03) 1px, transparent 1px),linear-gradient(90deg, rgba(15,23,42,.03) 1px, transparent 1px);
    background-size:38px 38px;
    mask-image:linear-gradient(to bottom, rgba(0,0,0,.2), transparent 75%);
    pointer-events:none;
  }

  .cf5-hero-grid{
    position:relative;z-index:2;
    display:grid;grid-template-columns:1.02fr .98fr;gap:52px;align-items:center;
  }
  .cf5-badge,.cf5-mini-badge{
    display:inline-flex;align-items:center;padding:8px 14px;border-radius:999px;
