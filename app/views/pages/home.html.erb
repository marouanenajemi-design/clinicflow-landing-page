<script>
  document.addEventListener("DOMContentLoaded", function () {
    const toggle = document.getElementById("cf5MenuToggle");
    const menu = document.getElementById("cf5MobileMenu");

    if (toggle && menu) {
      toggle.addEventListener("click", function () {
        menu.classList.toggle("cf5-open");
      });

      menu.querySelectorAll("a").forEach(function(link) {
        link.addEventListener("click", function () {
          menu.classList.remove("cf5-open");
        });
      });
    }
  });
</script>
