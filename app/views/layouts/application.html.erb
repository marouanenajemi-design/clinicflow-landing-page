<!DOCTYPE html>
<html>
  <head>
    <title>ClinicFlow - Smart Clinic Management Software</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="ClinicFlow is a modern clinic management platform for doctors and clinics to manage patients, appointments, prescriptions, and daily operations with ease.">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  </head>

  <body>
    <%= yield %>
  </body>
</html>
